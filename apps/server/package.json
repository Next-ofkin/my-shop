{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others npm:dev:*",
    "build": "tsc && npm run build:dashboard",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently npm:start:*",
    "migrate": "ts-node ./src/run-migrations.ts",
    "migrate:prod": "node ./dist/run-migrations.js",
    "start:with-migrations": "npm run migrate:prod && npm run start",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@vendure/asset-server-plugin": "3.5.5",
    "@vendure/core": "3.5.5",
    "@vendure/dashboard": "3.5.5",
    "@vendure/email-plugin": "3.5.5",
    "@vendure/graphiql-plugin": "3.5.5",
    "dotenv": "17.3.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@vendure/cli": "3.5.5",
    "concurrently": "9.2.1",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  }
}